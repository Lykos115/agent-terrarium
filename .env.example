# Agent Terrarium environment configuration
#
# Copy to .env and fill in values, or set them in your shell.

# Hermes API server URL (default: http://localhost:8642)
# HERMES_URL=http://localhost:8642

# API key for Hermes API server authentication.
# Falls back to API_SERVER_KEY (Hermes' own convention) if not set.
# HERMES_API_KEY=your-key-here
